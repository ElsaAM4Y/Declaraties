<ContentPage
    x:Class="Declaraties.Views.NotesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Aantekeningen"
    Style="{DynamicResource Page}">

    <Grid RowDefinitions="Auto,*" Padding="12" RowSpacing="12">

        <!-- BOVENSTE DEEL -->
        <VerticalStackLayout Grid.Row="0" Spacing="12">

            <Entry Text="{Binding Title}"
                   Placeholder="Titel"
                   Style="{DynamicResource Entry}"
                   Keyboard="Text"
                   IsTextPredictionEnabled="True"
                   IsSpellCheckEnabled="True"
                   TextTransform="None" />

            <Editor Text="{Binding Content}"
                    Placeholder="Aantekening..."
                    HeightRequest="140"
                    BackgroundColor="{DynamicResource CardBackgroundColor}"
                    TextColor="{DynamicResource PrimaryTextColor}"
                    Keyboard="Text"
                    IsTextPredictionEnabled="True"
                    IsSpellCheckEnabled="True"
                    TextTransform="None" />

            <HorizontalStackLayout Spacing="8">
                <Button Text="Nieuw" Command="{Binding NewNoteCommand}" />
                <Button Text="Opslaan" Command="{Binding SaveCommand}" />
                <Button Text="Verwijderen" Command="{Binding DeleteCommand}" />
            </HorizontalStackLayout>

        </VerticalStackLayout>

        <!-- LIJST MET NOTES -->
        <CollectionView x:Name="NotesList"
                        Grid.Row="1"
                        ItemsSource="{Binding Notes}"
                        SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border Style="{DynamicResource Border}" Margin="0,4">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNoteTapped" />
                        </Border.GestureRecognizers>

                        <Grid RowDefinitions="Auto,Auto">
                            <Label Text="{Binding Title}" FontSize="18" Style="{DynamicResource Label}" />
                            <Label Grid.Row="1"
                                   Text="{Binding Updated, StringFormat='Bijgewerkt: {0:G}'}"
                                   Style="{DynamicResource LabelSecond}" />
                        </Grid>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>
