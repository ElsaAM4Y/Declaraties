<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Declaraties.Views.TotalsPage"
             Title="TotalsPage"
             Background="{DynamicResource PageBackgroundColor}">
    <CollectionView ItemsSource="{Binding MonthTotals}" Margin="12">

        <CollectionView.Header>
            <Grid ColumnDefinitions="70,*,80,100" Padding="12,8" Margin="0,0,0,4">

                <Label Text="Maand"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource SecondaryTextColor}" />

                <Label Grid.Column="1"
                       Text="Dagen"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{DynamicResource SecondaryTextColor}" />

                <Label Grid.Column="2"
                       Text="Tarief"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{DynamicResource SecondaryTextColor}" />

                <Label Grid.Column="3"
                       Text="Totaal"
                       FontAttributes="Bold"
                       HorizontalOptions="End"
                       TextColor="{DynamicResource SecondaryTextColor}" />

            </Grid>
        </CollectionView.Header>

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Style="{StaticResource MainBorderStyle}" Margin="0,4">
                    <Grid ColumnDefinitions="*,80,80,120" Padding="4" MinimumHeightRequest="64">

                        <!-- Month + Year -->
                        <StackLayout VerticalOptions="Center">
                            <Label Text="{Binding MonthName}"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource PrimaryTextColor}" />
                            <Label Text="{Binding Year}"
                                   FontSize="12"
                                   TextColor="{DynamicResource SecondaryTextColor}" />
                        </StackLayout>

                        <!-- Total Times Working -->
                        <Label Grid.Column="1"
                               Text="{Binding TotalTimesWorking}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource AccentColor}" />

                        <!-- Rate -->
                        <Label Grid.Column="2"
                               Text="{Binding Rate, StringFormat='{}{0:C}'}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource PrimaryTextColor}" />

                        <!-- Total Amount -->
                        <Label Grid.Column="3"
                               Text="{Binding TotalAmount, StringFormat='{}{0:C}'}"
                               HorizontalOptions="End"
                               VerticalOptions="Center"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource PrimaryTextColor}" />

                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>
</ContentPage>