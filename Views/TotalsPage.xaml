<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Declaraties.Views.TotalsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Overzicht"
    Style="{DynamicResource Page}">

    <CollectionView ItemsSource="{Binding MonthTotals}" Margin="12">

        <!-- HEADER -->
        <CollectionView.Header>
            <FlexLayout
                Direction="Row"
                Wrap="NoWrap"
                AlignItems="Center"
                JustifyContent="SpaceBetween"
                Padding="12,8"
                Margin="0,0,0,4">

                <Label Text="Maand"
                       FontAttributes="Bold"
                       Style="{DynamicResource Label}" />

                <Label Text="Dagen"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       Style="{DynamicResource Label}" />

                <Label Text="Tarief"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       Style="{DynamicResource Label}" />

                <Label Text="Totaal"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="End"
                       Style="{DynamicResource Label}" />

            </FlexLayout>
        </CollectionView.Header>

        <!-- ITEMS -->
        <CollectionView.ItemTemplate>
            <DataTemplate>

                <Border Style="{DynamicResource Border}" Margin="0,4">
                    <FlexLayout
                        Direction="Row"
                        Wrap="NoWrap"
                        AlignItems="Center"
                        JustifyContent="SpaceBetween"
                        Padding="8">

                        <!-- MONTH + YEAR -->
                        <VerticalStackLayout FlexLayout.Basis="80">
                            <Label Text="{Binding MonthShort}"
                                   FontAttributes="Bold"
                                   Style="{DynamicResource Label}" />

                            <Label Text="{Binding Year}"
                                   FontSize="12"
                                   TextColor="{DynamicResource SecondaryTextColor}" />
                        </VerticalStackLayout>

                        <!-- TOTAL DAYS WORKED -->
                        <Label 
                            Text="{Binding TotalTimesWorking}"
                            HorizontalTextAlignment="Center"
                            TextColor="{DynamicResource AccentColor}"
                            Style="{DynamicResource Label}" />

                        <!-- RATE -->
                        <Label 
                            Text="{Binding Rate, StringFormat='€ {0:F2}'}"
                            HorizontalTextAlignment="Center"
                            Style="{DynamicResource Label}" />

                        <!-- TOTAL AMOUNT -->
                        <Label 
                            Text="{Binding TotalAmount, StringFormat='€ {0:F2}'}"
                            HorizontalTextAlignment="End"
                            Style="{DynamicResource Label}" />

                    </FlexLayout>
                </Border>

            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>
</ContentPage>
