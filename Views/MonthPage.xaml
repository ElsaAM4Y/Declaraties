<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Declaraties.Views.MonthPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Style="{DynamicResource Page}">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="12" Spacing="10">

                <!-- LABEL -->
                <Label Text="Tarief per dag"
                       FontAttributes="Bold"
                       Style="{DynamicResource Label}" />

                <!-- ENTRY -->
                <Entry Text="{Binding RatePerDay, Mode=TwoWay}"
                       Keyboard="Text"
                       Style="{DynamicResource Entry}" />

                <HorizontalStackLayout Spacing="8" HeightRequest="50">

                    <!-- MONTH PICKER -->
                    <Picker ItemsSource="{Binding Months}"
                            SelectedIndex="{Binding Month}"
                            WidthRequest="150"
                            Style="{DynamicResource Picker}" />

                    <!-- YEAR PICKER -->
                    <Picker ItemsSource="{Binding Years}"
                            SelectedItem="{Binding Year}"
                            WidthRequest="70"
                            Style="{DynamicResource Picker}" />

                    <!-- SAVE BUTTON -->
                    <Button Text="Opslaan"
                            Command="{Binding SaveCommand}"
                            HeightRequest="50"
                            HorizontalOptions="FillAndExpand"
                            Style="{DynamicResource Button}" />

                </HorizontalStackLayout>

                <!-- COLLECTIONVIEW -->
                <CollectionView ItemsSource="{Binding Records}"
                                ItemsUpdatingScrollMode="KeepScrollOffset"
                                SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="4"
                                  ColumnDefinitions="40,80,*"
                                  ColumnSpacing="8"
                                  MinimumHeightRequest="52">

                                <!-- DAY NUMBER -->
                                <Label Text="{Binding Date.Day}"
                                       VerticalOptions="Center"
                                       Style="{DynamicResource Label}" />

                                <!-- HOURS WORKED -->
                                <Entry Grid.Column="1"
                                       Text="{Binding DayTimesWorking, Mode=TwoWay}"
                                       Keyboard="Numeric"
                                       VerticalOptions="Center"
                                       Style="{DynamicResource Entry}" />

                                <!-- NOTE -->
                                <Entry Grid.Column="2"
                                       Text="{Binding DayNote, Mode=TwoWay}"
                                       VerticalOptions="Center"
                                       Style="{DynamicResource Entry}" />

                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- TOTALS BAR -->
        <Border Grid.Row="1"
                Padding="12"
                BackgroundColor="{DynamicResource EntryBackgroundColor}"
                StrokeThickness="0">

            <Label Text="{Binding TotalsText}"
                   FontSize="12"
                   HorizontalOptions="Center"
                   Style="{DynamicResource Label}" />
        </Border>

    </Grid>
</ContentPage>
