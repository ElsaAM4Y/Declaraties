<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Declaraties.Resources.Styles.DarkTheme">

    <!-- Brand -->
    <Color x:Key="BrandGreen">#009e60</Color>
    <Color x:Key="AccentNeon">#00FF66</Color>

    <!-- Page -->
    <Color x:Key="PageBackgroundColor">#121212</Color>

    <!-- Text -->
    <Color x:Key="PrimaryTextColor">#FFFFFF</Color>
    <Color x:Key="SecondaryTextColor">#AAAAAA</Color>

    <!-- Inputs -->
    <Color x:Key="EntryBackgroundColor">#262626</Color>
    <Color x:Key="PickerBackgroundColor">#262626</Color>
    <Color x:Key="PickerTextColor">#FFFFFF</Color>

    <!-- Cards -->
    <Color x:Key="CardBackgroundColor">#1E1E1E</Color>
    <Color x:Key="BorderColor">#333333</Color>

    <!-- Navigation -->
    <Color x:Key="NavigationBarBackgroundColor">#009e60</Color>
    <Color x:Key="NavigationBarTextColor">#FFFFFF</Color>

</ResourceDictionary>
