<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="Declaraties.Resources.Styles.DarkTheme">

    <!-- BRAND COLORS -->
    <Color x:Key="BrandGreen">#009e60</Color>
    <Color x:Key="AccentNeon">#00FF66</Color>

    <!-- DARK MODE BASE COLORS -->
    <Color x:Key="PageBackgroundColor">#121212</Color>
    <Color x:Key="TextColor">#FFFFFF</Color>

    <!-- INPUT FIELDS (lighter so they stand out) -->
    <Color x:Key="EntryBackgroundColor">#262626</Color>
    <Color x:Key="PickerBackgroundColor">#262626</Color>
    <Color x:Key="PickerTextColor">#FFFFFF</Color>

    <!-- CARDS / PANELS -->
    <Color x:Key="CardBackgroundColor">#1E1E1E</Color>
    <Color x:Key="BorderColor">#333333</Color>

    <!-- NAVIGATION BAR -->
    <Color x:Key="NavigationBarBackgroundColor">#009e60</Color>
    <Color x:Key="NavigationBarTextColor">#FFFFFF</Color>

    <!-- BUTTON STYLE -->
    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandGreen}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="HeightRequest" Value="44" />
    </Style>

    <!-- ENTRY STYLE -->
    <Style TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource EntryBackgroundColor}" />
        <Setter Property="TextColor" Value="{StaticResource TextColor}" />
        <Setter Property="HeightRequest" Value="44" />
    </Style>

    <!-- PICKER STYLE -->
    <Style TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{StaticResource PickerBackgroundColor}" />
        <Setter Property="TextColor" Value="{StaticResource PickerTextColor}" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="TitleColor" Value="#AAAAAA" />
    </Style>

    <!-- LABELS -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextColor}" />
    </Style>

    <!-- CONTENTPAGE BACKGROUND -->
    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource PageBackgroundColor}" />
    </Style>

</ResourceDictionary>
