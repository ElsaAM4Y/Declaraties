<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="Declaraties.Resources.Styles.GlobalStyles">

    <!-- ========================= -->
    <!--        BUTTON STYLE       -->
    <!-- ========================= -->
    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandGreen}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <!-- ========================= -->
    <!--         LABEL STYLE       -->
    <!-- ========================= -->
    <Style TargetType="Label">
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource TextColor},
                                     Dark={StaticResource TextColor}}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- ========================= -->
    <!--         ENTRY STYLE       -->
    <!-- ========================= -->
    <Style TargetType="Entry">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource EntryBackgroundColor},
                                     Dark={StaticResource EntryBackgroundColor}}" />

        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource TextColor},
                                     Dark={StaticResource TextColor}}" />

        <Setter Property="HeightRequest" Value="44" />
    </Style>

    <!-- ========================= -->
    <!--         PICKER STYLE      -->
    <!-- ========================= -->
    <Style TargetType="Picker">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource PickerBackgroundColor},
                                     Dark={StaticResource PickerBackgroundColor}}" />

        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource PickerTextColor},
                                     Dark={StaticResource PickerTextColor}}" />

        <Setter Property="TitleColor"
                Value="{AppThemeBinding Light=#555555,
                                     Dark=#AAAAAA}" />

        <Setter Property="HeightRequest" Value="44" />
    </Style>

    <!-- ========================= -->
    <!--       FRAME STYLE         -->
    <!-- ========================= -->
    <Style TargetType="Frame">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource CardBackgroundColor},
                                     Dark={StaticResource CardBackgroundColor}}" />

        <Setter Property="BorderColor"
                Value="{AppThemeBinding Light={StaticResource BorderColor},
                                     Dark={StaticResource BorderColor}}" />

        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <!-- ❗ IMPORTANT: Removed ContentPage style to allow theme switching -->
</ResourceDictionary>
